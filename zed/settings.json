{
  // Appearance
  "theme": {
    "mode": "dark",
    "light": "Monokai Nebula Light",
    "dark": "Bearded Theme Monokai Reversed",
  },
  "ui_font_family": "JetBrainsMono Nerd Font Mono",
  "ui_font_size": 16,
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_font_size": 14,
  "auto_install_extensions": {
    "bearded-theme": true,
  },

  // Panels & UI
  "project_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "sidebar_side": "right",
  },
  "search": {
    "button": false,
  },
  "collaboration_panel": {
    "button": false,
  },
  "tabs": {
    "git_status": true,
  },

  // Editor
  "vim_mode": true,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "format_on_save": "off",
  "show_whitespaces": "all",
  "edit_predictions": {
    "provider": "none",
  },

  // Agent servers
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },

  // LSP & languages
  "lsp": {
    "lua-language-server": {
      "settings": {
        "Lua": {
          "diagnostics": {
            "globals": ["vim"],
          },
        },
      },
    },
  },
  "languages": {
    "Lua": {
      "tab_size": 2,
    },
    "Go": {
      "hard_tabs": true,
    },
  },

  // Telemetry
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
